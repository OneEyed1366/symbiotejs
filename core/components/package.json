{
  "name": "@symbiotejs/components",
  "version": "0.1.0",
  "description": "Framework-agnostic component logic (state machines + render functions) for SymbioteJS — written once, inherited by every adapter (React, Vue, Angular, ...).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiotejs.git",
    "directory": "core/components"
  },
  "homepage": "https://github.com/OneEyed1366/symbiotejs/tree/master/core/components#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiotejs/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "build"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "module": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@symbiotejs/engine": "workspace:*"
  }
}
