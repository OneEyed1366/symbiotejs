{
  "name": "@symbiote-native/css-parser",
  "version": "0.2.2",
  "description": "Build-time CSS/SCSS/Less/Stylus compiler for SymbioteNative — compiles stylesheets to React Native style objects, resolved at runtime via a cross-adapter class-name registry.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiote-native.git",
    "directory": "core/css-parser"
  },
  "homepage": "https://github.com/OneEyed1366/symbiote-native/tree/master/core/css-parser#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiote-native/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./typescript-plugin": {
      "types": "./typescript-plugin.d.ts",
      "default": "./typescript-plugin.cjs"
    },
    "./generate-dts-cli": "./build/generate-dts-cli.js"
  },
  "files": [
    "build",
    "typescript-plugin.cjs",
    "typescript-plugin.d.ts"
  ],
  "bin": {
    "css-dts": "./build/generate-dts-cli.js"
  },
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "module": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      },
      "./typescript-plugin": {
        "types": "./typescript-plugin.d.ts",
        "default": "./typescript-plugin.cjs"
      },
      "./generate-dts-cli": "./build/generate-dts-cli.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-native/metro-babel-transformer": "catalog:",
    "postcss": "catalog:",
    "postcss-value-parser": "catalog:"
  },
  "devDependencies": {
    "sass": "catalog:",
    "less": "catalog:",
    "stylus": "catalog:",
    "@types/less": "catalog:",
    "@types/stylus": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
