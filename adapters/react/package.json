{
  "name": "@symbiote-native/react",
  "version": "0.2.4",
  "description": "SymbioteNative's React adapter — a react-reconciler host config (mutation mode) driving real native iOS/Android views through stock React Native Fabric.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiote-native.git",
    "directory": "adapters/react"
  },
  "homepage": "https://github.com/OneEyed1366/symbiote-native/tree/master/adapters/react#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiote-native/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./metro-css-parser": "./metro-css-parser.cjs"
  },
  "files": [
    "build",
    "metro-css-parser.cjs"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "module": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      },
      "./bootstrap": {
        "types": "./build/bootstrap.d.ts",
        "default": "./build/bootstrap.js"
      },
      "./metro-css-parser": "./metro-css-parser.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@symbiote-native/components": "workspace:*",
    "@symbiote-native/css-parser": "workspace:*",
    "@symbiote-native/engine": "workspace:*",
    "react-reconciler": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.86"
  },
  "devDependencies": {
    "@symbiote-native/test-utils": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "react": "catalog:"
  }
}
