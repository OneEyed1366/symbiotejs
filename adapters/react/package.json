{
  "name": "@symbiote/react",
  "version": "0.0.0",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./metro-css-parser": "./metro-css-parser.cjs"
  },
  "files": [
    "build",
    "metro-css-parser.cjs"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "module": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      },
      "./metro-css-parser": "./metro-css-parser.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@symbiote/components": "workspace:*",
    "@symbiote/css-parser": "workspace:*",
    "@symbiote/engine": "workspace:*",
    "react-reconciler": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.86"
  },
  "devDependencies": {
    "@symbiote/test-utils": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "react": "catalog:"
  }
}
