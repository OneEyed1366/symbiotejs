{
  "name": "@symbiotejs/angular",
  "version": "0.1.0",
  "description": "SymbioteJS's Angular adapter — a Renderer2/RendererFactory2 with DOM-less bootstrap driving real native iOS/Android views through the same engine as the other adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiotejs.git",
    "directory": "adapters/angular"
  },
  "homepage": "https://github.com/OneEyed1366/symbiotejs/tree/master/adapters/angular#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiotejs/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./build/angular/index.d.ts",
      "react-native": "./build/angular/index.js",
      "default": "./src/index.ts"
    },
    "./metro-css-parser": "./metro-css-parser.cjs"
  },
  "files": [
    "src",
    "build",
    "metro-css-parser.cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "pnpm run ng:build",
    "ng:build": "ngc -p tsconfig.angular.json",
    "typecheck": "tsc --build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@symbiotejs/components": "workspace:*",
    "@symbiotejs/css-parser": "workspace:*",
    "@symbiotejs/engine": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=20",
    "react-native": ">=0.86"
  },
  "devDependencies": {
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@symbiotejs/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
