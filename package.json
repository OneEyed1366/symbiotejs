{
  "name": "symbiote-native-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "typecheck": "tsc --build",
    "typecheck:watch": "tsc --build --watch",
    "build": "pnpm run typecheck && pnpm run fix-esm-extensions && pnpm --filter @symbiote-native/angular --filter @symbiote-native/slider run ng:build && pnpm run docs:build",
    "fix-esm-extensions": "node scripts/fix-esm-extensions.mjs adapters/react/build adapters/vue/build core/engine/build core/components/build core/test-utils/build",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "pnpm --filter @symbiote-native/docs-site dev",
    "docs:build": "pnpm --filter @symbiote-native/docs-site build",
    "docs:preview": "pnpm --filter @symbiote-native/docs-site preview",
    "format": "prettier --write \"{core,adapters,packages,apps}/**/*.{ts,tsx,js,json,astro,md,mdx,css}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"{core,adapters,packages,apps}/**/*.{ts,tsx,js,json,astro,md,mdx,css}\" \"*.{ts,json}\"",
    "lint": "eslint \"{core,adapters,packages}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"{core,adapters,packages}/**/*.{ts,tsx}\"",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "trust:publishers": "node scripts/trust-publishers.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "syncpack": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
