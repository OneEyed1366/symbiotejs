{
  "name": "symbiote-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --build",
    "typecheck:watch": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"{core,adapters,packages}/**/*.{ts,tsx,js,json}\" \"*.{ts,json}\"",
    "format:check": "prettier --check \"{core,adapters,packages}/**/*.{ts,tsx,js,json}\" \"*.{ts,json}\"",
    "lint": "eslint \"{core,adapters,packages}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"{core,adapters,packages}/**/*.{ts,tsx}\"",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "syncpack": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
