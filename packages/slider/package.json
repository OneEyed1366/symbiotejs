{
  "name": "@symbiote-native/slider",
  "version": "5.0.1",
  "description": "Third-party native Slider view wrapped for SymbioteNative — one framework-agnostic core, built once and reachable from the React, Vue, and Angular adapters.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiote-native.git",
    "directory": "packages/slider"
  },
  "homepage": "https://github.com/OneEyed1366/symbiote-native/tree/master/packages/slider#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiote-native/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/core/index.ts",
  "module": "src/core/index.ts",
  "types": "src/core/index.ts",
  "exports": {
    ".": "./src/core/index.ts",
    "./vue": "./src/vue/index.ts",
    "./react": "./src/react/index.ts",
    "./angular": {
      "types": "./build-ngc/angular/index.d.ts",
      "react-native": "./build-ngc/angular/index.js",
      "default": "./src/angular/index.ts"
    }
  },
  "files": [
    "src",
    "build",
    "build-ngc",
    "codegen-specs",
    "react-native.config.cjs",
    "symbiote-slider.podspec"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./build/core/index.js",
    "module": "./build/core/index.js",
    "types": "./build/core/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/core/index.d.ts",
        "default": "./build/core/index.js"
      },
      "./vue": {
        "types": "./build/vue/index.d.ts",
        "default": "./build/vue/index.js"
      },
      "./react": {
        "types": "./build/react/index.d.ts",
        "default": "./build/react/index.js"
      },
      "./angular": {
        "types": "./build-ngc/angular/index.d.ts",
        "react-native": "./build-ngc/angular/index.js",
        "default": "./src/angular/index.ts"
      }
    }
  },
  "codegenConfig": {
    "name": "RNCSlider",
    "type": "components",
    "jsSrcsDir": "codegen-specs",
    "android": {
      "javaPackageName": "com.reactnativecommunity.slider"
    },
    "ios": {
      "componentProvider": {
        "RNCSlider": "RNCSliderComponentView"
      }
    }
  },
  "scripts": {
    "prepare": "node ../../scripts/vendor-codegen-specs.cjs @react-native-community/slider src && pnpm run ng:build",
    "typecheck": "tsc --build",
    "clean": "rm -rf build-ngc",
    "ng:build": "pnpm run clean && ngc -p tsconfig.angular.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-native-community/slider": "catalog:",
    "@symbiote-native/components": "workspace:*"
  },
  "peerDependencies": {
    "@symbiote-native/angular": "workspace:*",
    "@symbiote-native/engine": ">=0.1.7",
    "@symbiote-native/react": "workspace:*",
    "@symbiote-native/vue": "workspace:*",
    "@angular/core": ">=20",
    "@vue/runtime-core": "^3.5.13",
    "react": ">=19.0.0",
    "react-native": ">=0.86",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "@symbiote-native/angular": {
      "optional": true
    },
    "@symbiote-native/react": {
      "optional": true
    },
    "@symbiote-native/vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@vue/runtime-core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@symbiote-native/angular": "workspace:*",
    "@symbiote-native/engine": "workspace:*",
    "@symbiote-native/react": "workspace:*",
    "@symbiote-native/test-utils": "workspace:*",
    "@symbiote-native/vue": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vue/runtime-core": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  }
}
