{
  "name": "@symbiotejs/slider",
  "version": "0.1.0",
  "description": "Third-party native Slider view wrapped for SymbioteJS — one framework-agnostic core, built once and reachable from the React, Vue, and Angular adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneEyed1366/symbiotejs.git",
    "directory": "packages/slider"
  },
  "homepage": "https://github.com/OneEyed1366/symbiotejs/tree/master/packages/slider#readme",
  "bugs": {
    "url": "https://github.com/OneEyed1366/symbiotejs/issues"
  },
  "author": "Andrey Prokopenko <psevdoproger@gmail.com>",
  "type": "module",
  "main": "src/core/index.ts",
  "module": "src/core/index.ts",
  "types": "src/core/index.ts",
  "exports": {
    ".": "./src/core/index.ts",
    "./vue": "./src/vue/index.ts",
    "./react": "./src/react/index.ts",
    "./angular": {
      "types": "./build-ngc/angular/index.d.ts",
      "react-native": "./build-ngc/angular/index.js",
      "default": "./src/angular/index.ts"
    }
  },
  "files": [
    "src",
    "build",
    "build-ngc"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./build/core/index.js",
    "module": "./build/core/index.js",
    "types": "./build/core/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/core/index.d.ts",
        "default": "./build/core/index.js"
      },
      "./vue": {
        "types": "./build/vue/index.d.ts",
        "default": "./build/vue/index.js"
      },
      "./react": {
        "types": "./build/react/index.d.ts",
        "default": "./build/react/index.js"
      },
      "./angular": {
        "types": "./build-ngc/angular/index.d.ts",
        "react-native": "./build-ngc/angular/index.js",
        "default": "./src/angular/index.ts"
      }
    }
  },
  "codegenConfig": {
    "name": "RNCSlider",
    "type": "components",
    "jsSrcsDir": "node_modules/@react-native-community/slider/src",
    "android": {
      "javaPackageName": "com.reactnativecommunity.slider"
    },
    "ios": {
      "componentProvider": {
        "RNCSlider": "RNCSliderComponentView"
      }
    }
  },
  "scripts": {
    "prepare": "pnpm run ng:build",
    "typecheck": "tsc --build",
    "ng:build": "ngc -p tsconfig.angular.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-native-community/slider": "catalog:",
    "@symbiotejs/components": "workspace:*",
    "@symbiotejs/engine": "workspace:*"
  },
  "peerDependencies": {
    "@symbiotejs/angular": "workspace:*",
    "@symbiotejs/react": "workspace:*",
    "@symbiotejs/vue": "workspace:*",
    "@angular/core": ">=20",
    "@vue/runtime-core": "^3.5.13",
    "react": ">=19.0.0",
    "react-native": ">=0.86",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "@symbiotejs/angular": {
      "optional": true
    },
    "@symbiotejs/react": {
      "optional": true
    },
    "@symbiotejs/vue": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@vue/runtime-core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@symbiotejs/angular": "workspace:*",
    "@symbiotejs/react": "workspace:*",
    "@symbiotejs/test-utils": "workspace:*",
    "@symbiotejs/vue": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vue/runtime-core": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  }
}
