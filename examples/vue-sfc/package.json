{
  "name": "vue-sfc-canary",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "pretypecheck": "css-dts .",
    "typecheck": "vue-tsc --noEmit -p tsconfig.typecheck.json",
    "dev": "react-native start --reset-cache",
    "start": "react-native start",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@symbiote-native/components": "catalog:",
    "@symbiote-native/engine": "catalog:",
    "@symbiote-native/slider": "catalog:",
    "@symbiote-native/vue": "catalog:",
    "@vue/runtime-core": "catalog:",
    "react": "catalog:",
    "react-native": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@babel/preset-env": "catalog:",
    "@babel/runtime": "catalog:",
    "@react-native-community/cli": "catalog:",
    "@react-native-community/cli-platform-android": "catalog:",
    "@react-native-community/cli-platform-ios": "catalog:",
    "@react-native/babel-preset": "catalog:",
    "@react-native/eslint-config": "catalog:",
    "@react-native/metro-config": "catalog:",
    "@react-native/typescript-config": "catalog:",
    "@symbiote-native/css-parser": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@vue/compiler-core": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "detox": "catalog:",
    "eslint": "catalog:rn-app",
    "jest": "catalog:",
    "jest-circus": "catalog:",
    "prettier": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
