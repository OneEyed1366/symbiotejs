{
  "name": "Canary",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "dev": "react-native start --reset-cache",
    "test": "vitest run",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.86.0",
    "@symbiote-native/android": "^0.1.1",
    "@symbiote-native/components": "^0.2.5",
    "@symbiote-native/engine": "^0.1.6",
    "@symbiote-native/navigation": "^1.0.0",
    "@symbiote-native/react": "^0.2.6",
    "@symbiote-native/slider": "^4.0.0",
    "@symbiote-native/splash-screen": "^2.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/codegen": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/gradle-plugin": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@symbiote-native/css-parser": "^0.2.2",
    "@symbiote-native/test-utils": "^0.1.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.0",
    "detox": "^20.51.4",
    "eslint": "^8.19.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.0",
    "vitest": "^4.1.9"
