{
  "name": "angular-canary",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "pnpm ng:build && react-native run-android",
    "ios": "pnpm ng:build && react-native run-ios",
    "lint": "eslint .",
    "dev": "symbiote-angular-dev --reset-cache",
    "start": "symbiote-angular-dev",
    "ng:build": "ngc -p tsconfig.angular.json",
    "e2e:build:ios": "pnpm ng:build && detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "pnpm ng:build && detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@angular/common": "^22",
    "@angular/compiler": "^22",
    "@angular/core": "^22",
    "@symbiote-native/android": "^0.1.2",
    "@symbiote-native/angular": "^0.6.1",
    "@symbiote-native/components": "^0.3.0",
    "@symbiote-native/engine": "^0.1.7",
    "@symbiote-native/navigation": "^2.0.2",
    "@symbiote-native/react": "^0.2.8",
    "@symbiote-native/sensors": "^0.2.0",
    "@symbiote-native/slider": "^5.0.2",
    "@symbiote-native/splash-screen": "^3.0.2",
    "expo-modules-core": "57.0.5",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^22",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/codegen": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/gradle-plugin": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@symbiote-native/css-parser": "^0.2.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.0",
    "detox": "^20.51.4",
    "eslint": "^8.19.0",
    "expo-modules-autolinking": "57.0.8",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.0"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
